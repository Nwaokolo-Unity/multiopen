generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

enum PlanTier {
  free
  pro
  team
  enterprise
}

enum LinkStatus {
  active
  paused
  expired
  deleted
}

enum ReportStatus {
  pending
  reviewed
  actioned
  dismissed
}

enum DeviceType {
  android
  ios
  desktop
  unknown
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  emailVerified    Boolean   @default(false)
  passwordHash     String?
  name             String
  avatarUrl        String?
  plan             PlanTier  @default(free)
  planExpiresAt    DateTime?
  stripeCustomerId String?   @unique
  timezone         String    @default("UTC")
  isAdmin          Boolean   @default(false)
  isSuspended      Boolean   @default(false)
  suspensionReason String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastLoginAt      DateTime?

  sessions Session[]
  links    Link[]
  reports  Report[]  @relation("ReviewedReports")

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Link {
  id           String     @id @default(uuid())
  userId       String
  slug         String     @unique
  name         String?
  title        String?
  description  String?
  thumbnailUrl String?
  ogFetchedAt  DateTime?
  status       LinkStatus @default(active)
  passwordHash String?
  clickCap     Int?
  expiresAt    DateTime?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targets Target[]
  clicks  Click[]
  reports Report[]

  @@index([userId])
  @@index([status])
  @@map("links")
}

model Target {
  id           String   @id @default(uuid())
  linkId       String
  platform     String
  canonicalUrl String
  deepLinkUri  String?
  position     Int      @default(0)
  isEnabled    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  link   Link    @relation(fields: [linkId], references: [id], onDelete: Cascade)
  clicks Click[]

  @@unique([linkId, platform])
  @@index([linkId])
  @@map("targets")
}

model Click {
  id             BigInt     @id @default(autoincrement())
  linkId         String
  targetId       String?
  clickedAt      DateTime   @default(now())
  ipCountry      String?
  deviceType     DeviceType @default(unknown)
  osName         String?
  browser        String?
  referrer       String?
  referrerDomain String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?

  link   Link    @relation(fields: [linkId], references: [id], onDelete: Cascade)
  target Target? @relation(fields: [targetId], references: [id], onDelete: SetNull)

  @@index([linkId, clickedAt(sort: Desc)])
  @@index([targetId])
  @@map("clicks")
}

model Report {
  id           String       @id @default(uuid())
  linkId       String
  reporterIp   String?
  reason       String
  description  String?
  status       ReportStatus @default(pending)
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime     @default(now())

  link       Link  @relation(fields: [linkId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ReviewedReports", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("reports")
}
